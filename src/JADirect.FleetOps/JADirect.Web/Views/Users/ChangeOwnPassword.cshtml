@{
    ViewData["Title"] = "Change Password";
}

@*
    View de troca de senha do próprio usuário.
    Acessível por qualquer usuário autenticado Manager ou Driver.
*@

<div class="max-w-md mx-auto py-12 px-4">
    <div class="mb-6">
        <a asp-controller="Home" asp-action="Index"
           class="text-[#008080] font-bold no-underline hover:text-[#006666] flex items-center">
            <i class="ri-arrow-left-line mr-1"></i> Back to Home
        </a>
    </div>

    <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
        <div class="p-8">

            @* Ícone e título *@
            <div class="flex flex-col items-center mb-8">
                <div class="h-16 w-16 bg-[#008080] rounded-2xl flex items-center justify-center text-white text-3xl shadow-lg mb-4">
                    <i class="ri-lock-password-line"></i>
                </div>
                <h1 class="text-2xl font-black text-slate-800">Change Password</h1>
                <p class="text-slate-500 text-sm mt-1">Enter your new password below</p>
            </div>

            @* Formulário *@
            <form asp-action="ChangeOwnPassword" method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                @* Exibe erros de validação do servidor *@
                <div asp-validation-summary="All" class="text-red-600 text-xs font-bold"></div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">
                        New Password
                    </label>
                    <input type="password"
                           name="newPassword"
                           id="newPassword"
                           class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-[#008080] outline-none font-semibold text-slate-700"
                           required />
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-1">
                        Confirm New Password
                    </label>
                    <input type="password"
                           name="confirmPassword"
                           id="confirmPassword"
                           class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-[#008080] outline-none font-semibold text-slate-700"
                           required />
                    @* Feedback visual de confirmação — atualizado pelo JavaScript abaixo *@
                    <p id="matchFeedback" class="text-[10px] mt-1 font-bold hidden"></p>
                </div>

                <button type="submit"
                        id="submitBtn"
                        class="w-full py-3 bg-[#008080] text-white rounded-2xl font-black text-sm shadow-lg hover:bg-[#006666] transition duration-200 flex items-center justify-center">
                    <i class="ri-shield-check-line mr-2"></i> Update Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        /// Validação client-side de confirmação de senha.
        /// Fornece feedback visual imediato sem precisar submeter o formulário.
        /// A validação real acontece no servidor — este JS é apenas UX.
        const newPassword     = document.getElementById('newPassword');
        const confirmPassword = document.getElementById('confirmPassword');
        const matchFeedback   = document.getElementById('matchFeedback');
        const submitBtn       = document.getElementById('submitBtn');

        function checkPasswords() {
            if (confirmPassword.value === '') {
                matchFeedback.classList.add('hidden');
                submitBtn.disabled = false;
                return;
            }

            if (newPassword.value === confirmPassword.value) {
                matchFeedback.textContent  = '✓ Passwords match';
                matchFeedback.className    = 'text-[10px] mt-1 font-bold text-green-600';
                submitBtn.disabled         = false;
            } else {
                matchFeedback.textContent  = '✗ Passwords do not match';
                matchFeedback.className    = 'text-[10px] mt-1 font-bold text-red-500';
                submitBtn.disabled         = true;
            }
        }

        newPassword.addEventListener('input', checkPasswords);
        confirmPassword.addEventListener('input', checkPasswords);
    </script>
}
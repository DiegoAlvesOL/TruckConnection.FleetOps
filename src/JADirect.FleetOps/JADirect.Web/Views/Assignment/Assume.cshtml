@{
ViewData["Title"] = "Assume Vehicle";
}

<style>
    .bg-teal { background-color: #008080; }
    .text-teal { color: #008080; }
    .btn-save-teal {
        background-color: #008080;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
    }
    .btn-save-teal:hover {
        background-color: #006666;
        transform: scale(1.02);
        color: white;
        box-shadow: 0 10px 20px -5px rgba(0, 128, 128, 0.4);
    }
    .btn-cancel-light {
        background-color: #f8fafc;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
    }
    .btn-qr {
        background-color: #f8fafc;
        color: #008080;
        border: 2px solid #008080;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
    }
    .btn-qr:hover {
        background-color: #008080;
        color: white;
    }
    ::placeholder {
        color: #cbd5e1 !important;
        opacity: 1;
    }
    #qr-video {
        width: 100%;
        border-radius: 12px;
        display: block;
    }
    #qr-canvas {
        display: none;
    }
</style>

<div class="max-w-2xl mx-auto p-4">

    <div class="mb-4">
        <a asp-controller="Driver" asp-action="SelectVehicle"
           class="text-teal text-decoration-none flex items-center font-medium">
            <i class="ri-arrow-left-line mr-1"></i> Back to Dashboard
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">

        @* Cabeçalho teal *@
        <div class="bg-teal text-white p-6 flex justify-center items-center">
            <h4 class="text-2xl font-bold mb-0 flex items-center">
                <i class="ri-car-line text-3xl mr-3"></i> Assume Vehicle
            </h4>
        </div>

        <div class="p-8">

            <p class="text-slate-500 text-sm mb-6 text-center">
                Enter the vehicle registration number or scan the QR code sticker inside the cab.
            </p>

            @* Mensagem de fallback quando a câmera não está disponível *@
            <div id="qr-fallback-message"
                 class="hidden mb-4 p-3 bg-amber-50 border border-amber-200 rounded-xl text-amber-700 text-sm text-center">
                <i class="ri-camera-off-line mr-1"></i>
                Camera not available. Please enter the registration number manually.
                This feature requires HTTPS.
            </div>

            @* Seção do scanner de QR code — oculta até o botão ser pressionado *@
            <div id="qr-scanner-section" class="hidden mb-6">
                <div class="relative">
                    <video id="qr-video" autoplay muted playsinline></video>
                    <canvas id="qr-canvas"></canvas>
                    <div class="mt-3 text-center">
                        <button type="button" id="btn-close-scanner"
                                class="btn-cancel-light px-6 py-2 text-sm">
                            <i class="ri-close-line mr-1"></i> Cancel Scan
                        </button>
                    </div>
                </div>
            </div>

            <form asp-controller="Assignment" asp-action="Assume" method="post">
                @Html.AntiForgeryToken()

                <div class="space-y-4">

                    @* Botão de abrir scanner *@
                    <button type="button" id="btn-open-scanner"
                            class="btn-qr w-full py-3 text-sm flex justify-center items-center gap-2">
                        <i class="ri-qr-scan-2-line text-lg"></i>
                        Scan QR Code
                    </button>

                    <div class="flex items-center gap-3 text-slate-300 text-xs">
                        <div class="flex-1 h-px bg-slate-200"></div>
                        <span>or enter manually</span>
                        <div class="flex-1 h-px bg-slate-200"></div>
                    </div>

                    <div>
                        <label for="registrationNo"
                               class="block text-lg font-medium text-gray-700 mb-2">
                            <i class="ri-roadster-line text-teal mr-1"></i> Registration Number
                        </label>
                        <input type="text"
                               id="registrationNo"
                               name="registrationNo"
                               inputmode="text"
                               autocomplete="off"
                               autocorrect="off"
                               autocapitalize="characters"
                               spellcheck="false"
                               placeholder="181D4812"
                               class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold tracking-widest uppercase text-center" />
                        <p class="text-xs text-slate-400 mt-2 text-center">
                            Example: 181D4812 or 451D90801
                        </p>
                    </div>
                </div>

                <div class="mt-8 space-y-4">
                    <button type="submit"
                            class="w-full btn-save-teal py-4 text-xl flex justify-center items-center shadow-lg">
                        <i class="ri-check-double-line mr-2"></i> Confirm Vehicle
                    </button>

                    <a asp-controller="Driver" asp-action="SelectVehicle"
                       class="w-full btn-cancel-light py-3 flex justify-center items-center no-underline">
                        <i class="ri-close-circle-line mr-2"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/jsqr.min.js"></script>
<script src="~/js/scanner.js"></script>
<script>
    // Converte automaticamente para maiúsculas enquanto o motorista digita manualmente.
    document.getElementById('registrationNo').addEventListener('input', function () {
        const cursorPosition = this.selectionStart;
        this.value = this.value
            .toUpperCase()
            .replace(/-/g, '')
            .replace(/\s/g, '');
        this.setSelectionRange(cursorPosition, cursorPosition);
    });
</script>
}
@model JADirect.Application.Documents.WalkaroundPdfData
@using JADirect.Application.Documents
@using JADirect.Domain.Models
@{
Layout = "_DocumentLayout";
ViewData["Title"] = string.Format("Walkaround Check — {0}", Model.VehicleRegistration);

string overallStatus = Model.Items.Any(i => i.State == "Defect")    ? "DEFECT"
: Model.Items.Any(i => i.State == "Attention") ? "ATTENTION"
: "OK";

string statusBg = overallStatus == "DEFECT"    ? "#DC2626"
: overallStatus == "ATTENTION" ? "#D97706"
: "#16A34A";
}

<style>
    .doc-header {
        background-color: #008080;
        color: white;
        padding: 1.25rem 1rem;
    }

    .ref-badge {
        display: inline-block;
        background-color: #0f766e;
        color: white;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
        letter-spacing: 0.05em;
        margin-top: 0.5rem;
    }

    .ref-label {
        color: #f0fdfa;
        font-size: 0.65rem;
        display: block;
    }

    .status-pill {
        display: inline-block;
        color: white;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 0.35rem 1rem;
        border-radius: 999px;
    }

    .meta-label {
        font-size: 0.7rem;
        color: #64748B;
        margin-bottom: 0.1rem;
    }

    .meta-value {
        font-size: 0.875rem;
        font-weight: 600;
        color: #0F172A;
    }

    .item-row {
        border-left: 4px solid transparent;
        padding: 0.6rem 0.75rem;
        background-color: white;
        margin-bottom: 2px;
        border-radius: 4px;
    }

    .item-row.status-good      { border-left-color: #16A34A; }
    .item-row.status-attention { border-left-color: #D97706; background-color: #FFFBEB; }
    .item-row.status-defect    { border-left-color: #DC2626; background-color: #FFF5F5; }

    .status-tag {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
    }

    .status-tag.good      { background-color: #DCFCE7; color: #16A34A; }
    .status-tag.attention { background-color: #FEF3C7; color: #D97706; }
    .status-tag.defect    { background-color: #FEE2E2; color: #DC2626; }

    .photo-evidence {
        width: 100%;
        max-height: 300px;
        object-fit: contain;
        border-radius: 6px;
        background-color: #f0fdfa;
        margin-top: 0.5rem;
        border: 1px solid #99d6d0;
    }

    .section-heading {
        font-size: 0.7rem;
        font-weight: 700;
        color: #0d9488;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.5rem 0.75rem 0.25rem;
        border-bottom: 2px solid #0d9488;
        margin-bottom: 4px;
    }

    .legal-notice {
        font-size: 0.7rem;
        color: #64748B;
        background-color: #f0fdfa;
        border: 1px solid #0d9488;
        border-radius: 6px;
        padding: 0.75rem;
        margin: 1rem;
        text-align: center;
        line-height: 1.6;
    }

    .doc-footer {
        background-color: #008080;
        color: #f0fdfa;
        font-size: 0.65rem;
        text-align: center;
        padding: 0.75rem;
        margin-top: 1.5rem;
    }
</style>

@* ── HEADER ──────────────────────────────────────────────────────────── *@
<div class="doc-header">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <div style="font-size: 1.1rem; font-weight: 700;">
                Walkaround Check
            </div>
            <div style="font-size: 0.75rem; color: #f0fdfa;">
                Daily Vehicle Inspection &nbsp;•&nbsp; JADirect FleetOps
            </div>
            <div class="ref-badge">
                <span class="ref-label">REF. No.</span>
                @Model.ReferenceNumber
            </div>
        </div>
        <div class="text-end">
            <span class="status-pill" style="background-color: @statusBg;">
                &#9679; @overallStatus
            </span>
            <div style="font-size: 0.65rem; color: #f0fdfa; margin-top: 0.25rem;">
                Overall Status
            </div>
        </div>
    </div>
</div>

@* ── METADADOS ────────────────────────────────────────────────────────── *@
<div class="mx-3 mt-3">
    <div class="bg-white rounded shadow-sm p-3"
         style="border: 1px solid #99d6d0;">
        <div class="row g-3">
            <div class="col-6">
                <div class="meta-label">Registration</div>
                <div class="meta-value">@Model.VehicleRegistration</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Vehicle</div>
                <div class="meta-value">@Model.VehicleMake @Model.VehicleModel</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Type</div>
                <div class="meta-value">@Model.VehicleType</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Driver</div>
                <div class="meta-value">@Model.DriverName</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Date</div>
                <div class="meta-value">@Model.CheckDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Time</div>
                <div class="meta-value">@Model.CheckDate.ToString("HH:mm")</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Odometer</div>
                <div class="meta-value">@Model.Odometer.ToString("N0") km</div>
            </div>
            <div class="col-6">
                <div class="meta-label">Submitted Via</div>
                <div class="meta-value">JADirect FleetOps</div>
            </div>
        </div>
    </div>
</div>

@* ── CONTADORES ───────────────────────────────────────────────────────── *@
<div class="mx-3 mt-3">
    <div class="row g-2 text-center">
        <div class="col-3">
            <div class="bg-white rounded p-2 shadow-sm"
                 style="border-top: 3px solid #16A34A; border: 1px solid #99d6d0;">
                <div style="font-size: 1.4rem; font-weight: 700; color: #16A34A;">
                    @Model.Items.Count(i => i.State == "Good")
                </div>
                <div style="font-size: 0.65rem; color: #64748B;">OK</div>
            </div>
        </div>
        <div class="col-3">
            <div class="bg-white rounded p-2 shadow-sm"
                 style="border-top: 3px solid #D97706; border: 1px solid #99d6d0;">
                <div style="font-size: 1.4rem; font-weight: 700; color: #D97706;">
                    @Model.Items.Count(i => i.State == "Attention")
                </div>
                <div style="font-size: 0.65rem; color: #64748B;">Attention</div>
            </div>
        </div>
        <div class="col-3">
            <div class="bg-white rounded p-2 shadow-sm"
                 style="border-top: 3px solid #DC2626; border: 1px solid #99d6d0;">
                <div style="font-size: 1.4rem; font-weight: 700; color: #DC2626;">
                    @Model.Items.Count(i => i.State == "Defect")
                </div>
                <div style="font-size: 0.65rem; color: #64748B;">Defect</div>
            </div>
        </div>
        <div class="col-3">
            <div class="bg-white rounded p-2 shadow-sm"
                 style="border-top: 3px solid #0d9488; border: 1px solid #99d6d0;">
                <div style="font-size: 1.4rem; font-weight: 700; color: #0d9488;">
                    @Model.Items.Count
                </div>
                <div style="font-size: 0.65rem; color: #64748B;">Total</div>
            </div>
        </div>
    </div>
</div>

@* ── CHECKLIST ────────────────────────────────────────────────────────── *@
<div class="mt-3">
    <div class="section-heading mx-3">Inspection Checklist</div>

    @{
    string? currentCategory = null;
    }

    @foreach (ChecklistItemResult item in Model.Items)
    {
    if (item.Category != currentCategory)
    {
    currentCategory = item.Category;
    <div class="px-3 pt-2 pb-1"
         style="font-size: 0.7rem; font-weight: 600;
                        color: #0d9488; text-transform: uppercase;
                        letter-spacing: 0.06em;">
        @item.Category
    </div>
    }

    string itemCssClass = item.State == "Attention" ? "status-attention"
    : item.State == "Defect"    ? "status-defect"
    : "status-good";

    string tagCssClass = item.State == "Attention" ? "attention"
    : item.State == "Defect"    ? "defect"
    : "good";

    string tagLabel = item.State == "Attention" ? "ATTENTION"
    : item.State == "Defect"    ? "DEFECT"
    : "OK";

    WalkaroundPdfPhotoData? photo = Model.Photos
    .FirstOrDefault(p => p.ChecklistItemId == item.ItemId);

    <div class="item-row @itemCssClass mx-3">
        <div class="d-flex justify-content-between align-items-start">
            <div style="font-size: 0.825rem; font-weight: 500;
                            color: #0F172A; flex: 1; margin-right: 0.5rem;">
                @item.Label
            </div>
            <span class="status-tag @tagCssClass flex-shrink-0">
                    @tagLabel
                </span>
        </div>

        @if (!string.IsNullOrEmpty(item.Note))
        {
        <div style="font-size: 0.75rem; color: #64748B; margin-top: 0.25rem;">
            @item.Note
        </div>
        }

        @if (photo != null && !string.IsNullOrEmpty(photo.StorageKey))
        {
        <img class="photo-evidence"
             src="@Url.Action("Photo", "Walkaround",
             new { storageKey = photo.StorageKey })"
             alt="Photo evidence for @item.Label"
             loading="lazy" />
        }
    </div>
    }
</div>

@* ── NOTA LEGAL ───────────────────────────────────────────────────────── *@
<div class="legal-notice">
    This walkaround check was completed and submitted digitally via JADirect FleetOps
    by the driver named above. The inspection record is stored securely and timestamped.
    This document is a true digital representation of the official record.
    Issued by DCODE Solutions — jadirect.ie
</div>

@* ── FOOTER ──────────────────────────────────────────────────────── *@
<div class="doc-footer">
    JADirect FleetOps &nbsp;•&nbsp; DCODE Solutions &nbsp;•&nbsp;
    @Model.VehicleRegistration &nbsp;•&nbsp;
    @Model.CheckDate.ToString("dd MMM yyyy") &nbsp;•&nbsp;
    Ref: @Model.ReferenceNumber
</div>
@model JADirect.Domain.Models.VehicleManageViewModel
@using JADirect.Domain.Enums

@{
    ViewData["Title"] = "Manage Vehicle";
}

<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    @* Botão Voltar *@
    <div class="mb-6">
        <a asp-action="Index" class="text-[#008080] font-bold no-underline hover:text-[#006666] flex items-center">
            <i class="ri-arrow-left-line mr-1"></i> Back to Fleet List
        </a>
    </div>

    @* CARD PRINCIPAL: Detalhes e Status *@
    <div class="bg-white rounded-3xl shadow-xl overflow-hidden mb-8 border border-gray-100">
        <div class="p-8">
            <div class="flex items-center mb-10">
                <div class="h-20 w-20 bg-[#008080] rounded-2xl flex items-center justify-center text-white text-3xl font-black shadow-lg">
                    @Model.Vehicle.RegistrationNo.Substring(0, Math.Min(2, Model.Vehicle.RegistrationNo.Length)).ToUpper()
                </div>
                <div class="ml-6">
                    <h1 class="text-3xl font-black text-slate-800">@Model.Vehicle.RegistrationNo</h1>
                    <p class="text-slate-500 font-medium">@Model.Vehicle.Manufacturer @Model.Vehicle.Model</p>
                    <span class="mt-2 px-3 py-1 inline-flex text-xs font-bold rounded-full @(Model.Vehicle.Status == VehicleStatus.Active ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                        @Model.Vehicle.Status
                    </span>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                @* Lado Esquerdo: Dados do Banco (Formulário de Detalhes) *@
                <div>
                    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Database Record</h3>
                    <form asp-action="Update" method="post" class="space-y-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Vehicle.Id" />

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase">Manufacturer</label>
                                <input asp-for="Vehicle.Manufacturer" class="mt-1 w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-[#008080] outline-none font-semibold text-slate-700" />
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase">Model</label>
                                <input asp-for="Vehicle.Model" class="mt-1 w-full p-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-[#008080] outline-none font-semibold text-slate-700" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase">Current Odometer (KM)</label>
                            <input asp-for="Vehicle.CurrentKm" type="number" class="mt-1 w-full p-3 bg-slate-50 border border-slate-200 rounded-xl font-semibold text-slate-700" />
                        </div>

                        <div class="mb-6">
                            <label class="block text-[10px] font-bold text-slate-500 uppercase">Vehicle Type</label>
                            <select asp-for="Vehicle.VehicleType" asp-items="Html.GetEnumSelectList<VehicleType>()" class="mt-1 w-full p-3 bg-slate-50 border border-slate-200 rounded-xl font-semibold text-slate-700 outline-none"></select>
                        </div>

                        <button type="submit" class="w-full py-3 border-2 border-[#008080] text-[#008080] hover:bg-[#008080] hover:text-white rounded-2xl font-black text-xs transition duration-200 flex items-center justify-center uppercase tracking-wider">
                            <i class="ri-edit-line mr-2"></i> Update Vehicle Details
                        </button>
                    </form>
                </div>

                @* Lado Direito: Operational Control (Formulário de Status) *@
                <div class="bg-slate-50/50 p-6 rounded-3xl border border-slate-100 flex flex-col justify-between">
                    <div>
                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Operational Control</h3>

                        <form asp-action="UpdateStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="vehicleId" value="@Model.Vehicle.Id" />

                            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 mb-6">
                                <label class="block text-[10px] font-bold text-slate-500 uppercase mb-3">Update Fleet Status</label>
                                <select name="newStatus" asp-items="Html.GetEnumSelectList<VehicleStatus>()" class="w-full p-3 border border-slate-200 rounded-xl font-bold text-slate-800 focus:ring-2 focus:ring-[#008080] outline-none mb-4">
                                </select>
                                <p class="text-[10px] text-slate-400 italic">Changing the status affects driver availability in real-time.</p>
                            </div>

                            <button type="submit" class="w-full py-4 bg-[#008080] text-white rounded-2xl font-black text-sm shadow-lg shadow-teal-900/20 hover:bg-[#006666] transition duration-200 flex items-center justify-center">
                                <i class="ri-refresh-line mr-2 text-lg"></i> UPDATE STATUS ONLY
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* SEÇÃO: Histórico de Walkaround Check *@
    <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-50 bg-slate-50/30 flex justify-between items-center">
            <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight">
                <i class="ri-clipboard-line mr-2 text-[#008080]"></i> Walkaround Check History
            </h3>
            <span class="text-[10px] font-bold bg-slate-200 text-slate-600 px-3 py-1 rounded-full uppercase">Last 30 Records</span>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase">Date</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase">Driver</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase">Odometer</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase">Status</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-400 uppercase">Location</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.WalkaroundHistory.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-10 text-center text-slate-400 italic">
                                No walkaround checks recorded for this vehicle.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var check in Model.WalkaroundHistory)
                        {
                            <tr class="hover:bg-slate-50/80 transition">

                                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-slate-700">
                                    @check.CheckDate.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 font-medium">
                                    @check.DriverName
                                </td>

                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-bold">
                                    @check.Odometer.ToString("N0") KM
                                </td>

                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2 py-1 text-[10px] font-black rounded @(check.IsPassed ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                                        @(check.IsPassed ? "PASSED" : "FAILED")
                                    </span>
                                </td>

                                <td class="px-6 py-4 whitespace-nowrap text-[10px]">
                                    @if (check.Location != null)
                                    {
                                        <a href="@check.Location" target="_blank"
                                           class="text-[#008080] hover:text-[#006666] font-bold flex items-center gap-1">
                                            <i class="ri-map-pin-2-line"></i> View Map
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-slate-300 italic">No GPS</span>
                                    }
                                </td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
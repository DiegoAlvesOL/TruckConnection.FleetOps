@model JADirect.Domain.Entities.DailyLog
@{
ViewData["Title"] = "Confirm Daily Log";
string vehicleDisplay      = ViewBag.VehicleDisplay ?? string.Empty;
string vehicleRegistration = ViewBag.VehicleRegistration ?? string.Empty;
}

<style>
    .bg-teal { background-color: #008080; }
    .text-teal { color: #008080; }
    .btn-confirm-teal {
        background-color: #008080;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
    }
    .btn-confirm-teal:hover {
        background-color: #006666;
        transform: scale(1.02);
        color: white;
        box-shadow: 0 10px 20px -5px rgba(0, 128, 128, 0.4);
    }
    .btn-edit-light {
        background-color: #f8fafc;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
    }
</style>

<div class="max-w-2xl mx-auto p-4">

    <div class="mb-4">
        <a asp-controller="DailyLog" asp-action="Create"
           class="text-teal text-decoration-none flex items-center font-medium">
            <i class="ri-arrow-left-line mr-1"></i> Back to Form
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">

        <div class="bg-teal text-white p-6">
            <div class="flex justify-center items-center mb-3">
                <h4 class="text-2xl font-bold mb-0 flex items-center">
                    <i class="ri-check-double-line text-3xl mr-3"></i> Confirm Daily Log
                </h4>
            </div>
            @if (!string.IsNullOrEmpty(vehicleRegistration))
            {
            <div class="text-center">
                <p class="text-teal-100 text-sm font-medium">@vehicleDisplay</p>
                <p class="text-white font-black tracking-widest text-lg">@vehicleRegistration</p>
            </div>
            }
        </div>

        <div class="p-8">

            <p class="text-slate-500 text-sm text-center mb-6">
                Please review your entries below before confirming.
            </p>

            <div class="space-y-3 mb-6" id="summary-values">

                <div class="flex justify-between items-center py-3 px-4 bg-slate-50 rounded-xl border border-slate-200">
                    <span class="text-slate-500 text-sm font-medium flex items-center gap-2">
                        <i class="ri-calendar-check-line text-teal"></i> Log Date
                    </span>
                    <span class="font-black text-slate-800">@Model.LogDate.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="flex justify-between items-center py-3 px-4 bg-slate-50 rounded-xl border border-slate-200">
                    <span class="text-slate-500 text-sm font-medium flex items-center gap-2">
                        <i class="ri-edit-box-line text-teal"></i> Deliveries
                    </span>
                    <span class="font-black text-slate-800 text-xl" data-field="deliveries" data-value="@Model.Deliveries">
                        @Model.Deliveries
                    </span>
                </div>

                <div class="flex justify-between items-center py-3 px-4 bg-slate-50 rounded-xl border border-slate-200">
                    <span class="text-slate-500 text-sm font-medium flex items-center gap-2">
                        <i class="ri-arrow-left-right-line text-teal"></i> Collections
                    </span>
                    <span class="font-black text-slate-800 text-xl" data-field="collections" data-value="@Model.Collections">
                        @Model.Collections
                    </span>
                </div>

                <div class="flex justify-between items-center py-3 px-4 bg-slate-50 rounded-xl border border-slate-200">
                    <span class="text-slate-500 text-sm font-medium flex items-center gap-2">
                        <i class="ri-arrow-go-back-line text-teal"></i> Returns
                    </span>
                    <span class="font-black text-slate-800 text-xl" data-field="returns" data-value="@Model.Returns">
                        @Model.Returns
                    </span>
                </div>

                @if (Model.CurrentOdometer.HasValue)
                {
                <div class="flex justify-between items-center py-3 px-4 bg-slate-50 rounded-xl border border-slate-200">
                        <span class="text-slate-500 text-sm font-medium flex items-center gap-2">
                            <i class="ri-dashboard-3-line text-teal"></i> Odometer
                        </span>
                    <span class="font-black text-slate-800">@Model.CurrentOdometer km</span>
                </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                <div class="py-3 px-4 bg-slate-50 rounded-xl border border-slate-200">
                        <span class="text-slate-500 text-sm font-medium flex items-center gap-2 mb-2">
                            <i class="ri-chat-1-line text-teal"></i> Notes
                        </span>
                    <p class="text-slate-700 text-sm">@Model.Notes</p>
                </div>
                }

            </div>

            @* Container de alertas preenchido pelo JavaScript *@
            <div id="outlier-alerts" class="hidden mb-6">
                <div class="flex items-start gap-3 p-4 bg-amber-50 border border-amber-200 rounded-xl">
                    <i class="ri-error-warning-line text-amber-500 text-xl shrink-0 mt-0.5"></i>
                    <div>
                        <p class="text-sm font-black text-amber-700 uppercase tracking-wide mb-2">
                            Please review before confirming
                        </p>
                        <ul id="outlier-list" class="space-y-1 text-sm text-amber-700 list-disc list-inside">
                        </ul>
                        <p class="text-xs text-amber-600 mt-2">
                            You can still confirm if the values are correct.
                        </p>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                <form asp-controller="DailyLog" asp-action="Confirm" method="post" id="confirm-form">
                    @Html.AntiForgeryToken()
                    @* Campo hidden preenchido pelo script: true se outliers foram detectados e o motorista confirmou assim mesmo. *@
                    <input type="hidden" name="confirmedByDriver" id="confirmed-by-driver" value="false" />
                    <button type="submit"
                            class="w-full btn-confirm-teal py-4 text-xl flex justify-center items-center shadow-lg">
                        <i class="ri-check-double-line mr-2"></i> Confirm and Submit
                    </button>
                </form>

                <a asp-controller="DailyLog" asp-action="Create"
                   class="w-full btn-edit-light py-3 flex justify-center items-center no-underline">
                    <i class="ri-edit-line mr-2"></i> Edit Values
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    var RETURNS_OUTLIER_THRESHOLD = 15;

    document.addEventListener('DOMContentLoaded', function () {
        var returns = parseInt(document.querySelector('[data-field="returns"]').dataset.value) || 0;

        if (returns <= RETURNS_OUTLIER_THRESHOLD) {
            return;
        }

        // Outlier detectado: exibe o alerta e marca o campo hidden como true.
        // O valor true será enviado ao backend quando o motorista confirmar,
        // sinalizando que ele estava ciente do valor incomum.
        document.getElementById('confirmed-by-driver').value = 'true';

        var container = document.getElementById('outlier-alerts');
        var list      = document.getElementById('outlier-list');

        var item = document.createElement('li');
        item.textContent = 'Returns (' + returns + ') is unusually high. '
            + 'Please confirm this value is correct before submitting.';
        list.appendChild(item);

        container.classList.remove('hidden');
    });
</script>
}
@model JADirect.Domain.Entities.DailyLog

@{
    ViewData["Title"] = "Daily Operational Log";
    var today = DateTime.Now.Date;
    var minimumDate = today.AddDays(-7);
    var todayFormatted = today.ToString("yyyy-MM-dd");
    var minimumDateFormatted = minimumDate.ToString("yyyy-MM-dd");

    string assignedRegistration = ViewBag.AssignedVehicleRegistration ?? string.Empty;
    string assignedDisplay      = ViewBag.AssignedVehicleDisplay      ?? string.Empty;
    int    assignedVehicleId    = ViewBag.AssignedVehicleId            ?? 0;
}

<style>
    .bg-teal { background-color: #008080; }
    .text-teal { color: #008080; }
    .btn-save-teal {
        background-color: #008080;
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: 0.3s;
    }
    .btn-save-teal:hover {
        background-color: #006666;
        transform: scale(1.02);
        color: white;
        box-shadow: 0 10px 20px -5px rgba(0, 128, 128, 0.4);
    }
    .btn-cancel-light {
        background-color: #f8fafc;
        color: #64748b;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
    }
    ::placeholder {
        color: #cbd5e1 !important;
        opacity: 1;
    }
</style>

<div class="max-w-2xl mx-auto p-4">

    <div class="mb-4">
        <a asp-controller="Driver" asp-action="SelectVehicle"
           class="text-teal text-decoration-none flex items-center font-medium">
            <i class="ri-arrow-left-line mr-1"></i> Back to Dashboard
        </a>
    </div>

    <div class="w-full mx-auto mb-12">
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100">

            <div class="bg-teal text-white p-6 flex justify-center items-center">
                <h4 class="text-2xl font-bold mb-0 flex items-center">
                    <i class="ri-truck-line text-3xl mr-3"></i> Daily Log Submission
                </h4>
            </div>

            <div class="p-8">

                @* Card somente leitura com o veículo do assignment ativo *@
                <div class="flex items-center gap-4 p-4 bg-teal-50 border border-teal-200 rounded-xl mb-6">
                    <div class="w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center shrink-0">
                        <i class="ri-car-line text-white text-lg"></i>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-teal-500 mb-0.5">
                            Assigned Vehicle
                        </p>
                        <p class="text-base font-black text-slate-800 leading-tight">
                            @assignedRegistration
                        </p>
                        @if (!string.IsNullOrEmpty(assignedDisplay))
                        {
                            <p class="text-xs text-slate-500">@assignedDisplay</p>
                        }
                    </div>
                    <div class="ml-auto">
                        <span class="text-xs font-bold text-teal-600 bg-teal-100 px-2 py-1 rounded-lg">
                            Active
                        </span>
                    </div>
                </div>

                <form asp-action="Create" method="post" id="dailyLogForm">
                    @Html.AntiForgeryToken()

                    @* VehicleId como hidden input — populado pelo assignment, nunca editável pelo motorista *@
                    <input type="hidden" name="VehicleId" value="@assignedVehicleId" />

                    <div asp-validation-summary="ModelOnly"
                         class="text-red-700 bg-red-50 border border-red-200 p-3 rounded-lg mb-6 text-sm"></div>

                    <div class="space-y-6">
                        <div>
                            <label asp-for="LogDate" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-calendar-check-line text-teal mr-1"></i> Log Date
                            </label>
                            <input asp-for="LogDate"
                                   type="date"
                                   min="@minimumDateFormatted"
                                   max="@todayFormatted"
                                   value="@todayFormatted"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold" />
                        </div>

                        <div>
                            <label asp-for="Deliveries" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-edit-box-line text-teal mr-1"></i> Deliveries Completed
                            </label>
                            <input asp-for="Deliveries"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold limit-999"
                                   type="text" inputmode="numeric" placeholder="0" value="" required />
                        </div>

                        <div>
                            <label asp-for="Collections" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-arrow-left-right-line text-teal mr-1"></i> Collections Made
                            </label>
                            <input asp-for="Collections"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold limit-999"
                                   type="text" inputmode="numeric" placeholder="0" value="" required />
                        </div>

                        <div>
                            <label asp-for="Returns" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-arrow-go-back-line text-teal mr-1"></i> Returns Count
                            </label>
                            <input asp-for="Returns"
                                   class="w-full p-4 text-xl border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all font-semibold limit-999"
                                   type="text" inputmode="numeric" placeholder="0" value="" required />
                        </div>

                        <div>
                            <label asp-for="CurrentOdometer" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-dashboard-3-line text-teal mr-1"></i> Final Odometer (Optional)
                            </label>
                            <input asp-for="CurrentOdometer"
                                   class="w-full p-4 text-xl border border-gray-200 bg-gray-50 rounded-xl focus:ring-4 focus:ring-gray-100 focus:border-gray-400 transition-all text-gray-600 font-medium"
                                   type="text" inputmode="numeric" placeholder="KM reading" value="" />
                        </div>

                        <div>
                            <label asp-for="Notes" class="block text-lg font-medium text-gray-700 mb-2">
                                <i class="ri-chat-1-line text-teal mr-1"></i> Notes / Observations
                            </label>
                            <textarea asp-for="Notes" rows="2"
                                      class="w-full p-4 text-lg border border-gray-300 rounded-xl focus:ring-4 focus:ring-teal-100 focus:border-teal-600 transition-all"
                                      placeholder="Any issues or remarks..."></textarea>
                        </div>
                    </div>

                    <div class="mt-10 space-y-4">
                        <button type="submit"
                                class="w-full btn-save-teal py-4 text-xl flex justify-center items-center shadow-lg">
                            <i class="ri-eye-line mr-2"></i> Review & Confirm
                        </button>

                        <a asp-controller="Driver" asp-action="SelectVehicle"
                           class="w-full btn-cancel-light py-3 flex justify-center items-center no-underline">
                            <i class="ri-close-circle-line mr-2"></i> Cancel Entry
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.limit-999').forEach(input => {
        input.addEventListener('input', function() {
            this.value = this.value.replace(/[^0-9]/g, '');
            if (this.value !== '' && parseInt(this.value) > 999) {
                this.value = '999';
            }
        });
    });
</script>
}
@using JADirect.Domain.Enums
@using JADirect.Domain.Models
@model DriverDashboardModel
@{
    ViewData["Title"] = "My Journey";

    bool stepVehicleComplete    = Model.JourneyStep != JourneyStep.NeedsVehicle;
    bool stepWalkaroundActive   = Model.JourneyStep == JourneyStep.NeedsWalkaround;
    bool stepWalkaroundComplete = Model.JourneyStep == JourneyStep.Ready;
    bool stepReadyActive        = Model.JourneyStep == JourneyStep.Ready;

    // Cores do semáforo para o hero card de walkaround.
    // Calculadas aqui para evitar bloco @{} dentro do else if, que é inválido em Razor.
    string walkaroundBorderColor = "border-amber-200";
    string walkaroundBgColor     = "bg-amber-50";
    string walkaroundIconColor   = "text-amber-600";
    string walkaroundIconBg      = "bg-amber-100 border-amber-200";
    string walkaroundBadgeColor  = "text-amber-500";
    string walkaroundMessage     = "Complete the safety inspection to unlock the daily log.";

    if (Model.VehicleCompliance != null)
    {
        walkaroundMessage = Model.VehicleCompliance.StatusMessage;

        if (Model.VehicleCompliance.StatusColor == "Red")
        {
            walkaroundBorderColor = "border-red-200";
            walkaroundBgColor     = "bg-red-50";
            walkaroundIconColor   = "text-red-600";
            walkaroundIconBg      = "bg-red-100 border-red-200";
            walkaroundBadgeColor  = "text-red-500";
        }
        else if (Model.VehicleCompliance.StatusColor == "Green")
        {
            walkaroundBorderColor = "border-green-200";
            walkaroundBgColor     = "bg-green-50";
            walkaroundIconColor   = "text-green-600";
            walkaroundIconBg      = "bg-green-100 border-green-200";
            walkaroundBadgeColor  = "text-green-500";
        }
    }
}

<div class="space-y-6 max-w-2xl mx-auto pb-10">

    @* STEPPER — 3 passos da jornada diária (compacto) *@
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 px-4 py-3">
        <div class="flex items-center justify-between">

            @* Passo 1: Assumir Veículo *@
            <div class="flex flex-col items-center flex-1">
                <div class="@(stepVehicleComplete
                        ? "bg-teal-600 border-teal-600 text-white"
                        : "border-2 border-teal-600 text-teal-600 bg-white")
                     w-7 h-7 rounded-full flex items-center justify-center font-black text-xs transition-all">
                    @if (stepVehicleComplete)
                    {
                        <i class="ri-check-line text-xs"></i>
                    }
                    else
                    {
                        <span>1</span>
                    }
                </div>
                <span class="mt-1.5 text-[9px] font-bold uppercase tracking-wider
                      @(stepVehicleComplete ? "text-teal-600" : "text-slate-700")">
                    Assume Vehicle
                </span>
            </div>

            @* Conector 1-2 *@
            <div class="h-px flex-1 max-w-[48px] @(stepVehicleComplete ? "bg-teal-400" : "bg-slate-200")"></div>

            @* Passo 2: Walkaround *@
            <div class="flex flex-col items-center flex-1">
                <div class="@(stepWalkaroundComplete
                        ? "bg-teal-600 border-teal-600 text-white"
                        : stepWalkaroundActive
                            ? "border-2 border-teal-600 text-teal-600 bg-white"
                            : "border-2 border-slate-200 text-slate-300 bg-white")
                     w-7 h-7 rounded-full flex items-center justify-center font-black text-xs transition-all">
                    @if (stepWalkaroundComplete)
                    {
                        <i class="ri-check-line text-xs"></i>
                    }
                    else
                    {
                        <span>2</span>
                    }
                </div>
                <span class="mt-1.5 text-[9px] font-bold uppercase tracking-wider
                      @(stepWalkaroundComplete || stepWalkaroundActive ? "text-teal-600" : "text-slate-300")">
                    Walkaround
                </span>
            </div>

            @* Conector 2-3 *@
            <div class="h-px flex-1 max-w-[48px] @(stepWalkaroundComplete ? "bg-teal-400" : "bg-slate-200")"></div>

            @* Passo 3: Ready *@
            <div class="flex flex-col items-center flex-1">
                <div class="@(stepReadyActive
                        ? "bg-teal-600 border-teal-600 text-white"
                        : "border-2 border-slate-200 text-slate-300 bg-white")
                     w-7 h-7 rounded-full flex items-center justify-center font-black text-xs transition-all">
                    @if (stepReadyActive)
                    {
                        <i class="ri-check-line text-xs"></i>
                    }
                    else
                    {
                        <span>3</span>
                    }
                </div>
                <span class="mt-1.5 text-[9px] font-bold uppercase tracking-wider
                      @(stepReadyActive ? "text-teal-600" : "text-slate-300")">
                    Ready
                </span>
            </div>

        </div>
    </div>

    @* HERO CARD — estado contextual da jornada *@

    @if (Model.JourneyStep == JourneyStep.NeedsVehicle)
    {
        @* Estado 1: motorista ainda não assumiu um veículo *@
        <div class="rounded-3xl border-2 border-amber-200 bg-amber-50 p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl bg-amber-100 border border-amber-200 flex items-center justify-center shrink-0">
                    <i class="ri-car-line text-2xl text-amber-600"></i>
                </div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-amber-500 mb-1">Step 1 of 3</p>
                    <h2 class="text-xl font-black text-slate-800 leading-tight">Assume your vehicle</h2>
                    <p class="text-sm text-slate-500 mt-1">
                        You don't have an active vehicle for today. Enter the registration or scan the QR code to get started.
                    </p>
                </div>
            </div>
            <div class="mt-5 space-y-3">
                <a href="/Assignment/Assume"
                   class="flex items-center justify-center gap-2 w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 rounded-2xl transition-all shadow-md shadow-amber-200 text-sm">
                    <i class="ri-qr-scan-2-line text-lg"></i>
                    Assume a Vehicle
                </a>
                <button disabled
                        class="w-full bg-slate-100 text-slate-300 font-bold py-3 rounded-2xl cursor-not-allowed border border-slate-200 text-sm">
                    <i class="ri-shield-check-line mr-1"></i> Walkaround - complete step 1 first
                </button>
                <button disabled
                        class="w-full bg-slate-100 text-slate-300 font-bold py-3 rounded-2xl cursor-not-allowed border border-slate-200 text-sm">
                    <i class="ri-lock-line mr-1"></i> Daily Log - complete steps 1 and 2 first
                </button>
            </div>
        </div>
    }
    else if (Model.JourneyStep == JourneyStep.NeedsWalkaround)
    {
        @* Estado 2: veículo assumido, walkaround pendente.
           Cores aplicadas via variáveis calculadas no bloco @{} do topo,
           seguindo o semáforo de compliance do FleetService.
           Dados do veículo exibidos abaixo do título. *@
        <div class="rounded-3xl border-2 @walkaroundBorderColor @walkaroundBgColor p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl @walkaroundIconBg flex items-center justify-center shrink-0">
                    <i class="ri-shield-check-line text-2xl @walkaroundIconColor"></i>
                </div>
                <div class="flex-1">
                    <p class="text-[10px] font-black uppercase tracking-widest @walkaroundBadgeColor mb-1">Step 2 of 3</p>
                    <h2 class="text-xl font-black text-slate-800 leading-tight">Walkaround required</h2>

                    @if (Model.VehicleCompliance != null)
                    {
                        <div class="mt-2 space-y-0.5">
                            <p class="text-sm text-slate-600">
                                <span class="text-slate-400">Vehicle assumed:</span>
                                <span class="font-semibold">@Model.VehicleCompliance.Manufacturer @Model.VehicleCompliance.Model</span>
                            </p>
                            <p class="text-sm text-slate-600">
                                <span class="text-slate-400">Registration No:</span>
                                <span class="font-semibold">@Model.VehicleCompliance.RegistrationNo</span>
                            </p>
                        </div>
                    }

                    <p class="text-sm text-slate-500 mt-2">@walkaroundMessage</p>
                </div>
            </div>
            <div class="mt-5 space-y-3">
                <a href="/Walkaround/Create"
                   class="flex items-center justify-center gap-2 w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-2xl transition-all shadow-md shadow-teal-200 text-sm">
                    <i class="ri-shield-check-line text-lg"></i>
                    Start Walkaround Check
                </a>
                <button disabled
                        class="w-full bg-slate-100 text-slate-300 font-bold py-3 rounded-2xl cursor-not-allowed border border-slate-200 text-sm">
                    <i class="ri-lock-line mr-1"></i> Daily Log - complete walkaround first
                </button>
                <form asp-controller="Assignment" asp-action="Unassign" method="post" class="w-full">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full border-2 border-slate-200 text-slate-400 hover:border-red-300 hover:text-red-500 font-bold py-2.5 rounded-2xl transition-all text-sm">
                        <i class="ri-arrow-go-back-line mr-1"></i> Return Vehicle
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        @* Estado 3: jornada completa, tudo liberado.
           Quando StatusColor == "Yellow", exibe aviso âmbar informando que o walkaround
           expira amanhã. O motorista ainda pode operar normalmente. *@
        <div class="rounded-3xl border-2 border-teal-200 bg-teal-50 p-6 shadow-sm">
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-2xl bg-teal-600 flex items-center justify-center shrink-0 shadow-lg shadow-teal-200">
                    <i class="ri-check-double-line text-2xl text-white"></i>
                </div>
                <div class="flex-1">
                    <p class="text-[10px] font-black uppercase tracking-widest text-teal-500 mb-1">Ready to go</p>
                    <h2 class="text-xl font-black text-slate-800 leading-tight">All good - start your day</h2>

                    @if (Model.VehicleCompliance != null)
                    {
                        <div class="mt-2 space-y-0.5">
                            <p class="text-sm text-slate-600">
                                <span class="text-slate-400">Vehicle assumed:</span>
                                <span class="font-semibold">@Model.VehicleCompliance.Manufacturer @Model.VehicleCompliance.Model</span>
                            </p>
                            <p class="text-sm text-slate-600">
                                <span class="text-slate-400">Registration No:</span>
                                <span class="font-semibold">@Model.VehicleCompliance.RegistrationNo</span>
                            </p>
                        </div>

                        @if (Model.VehicleCompliance.StatusColor == "Yellow")
                        {
                            <div class="mt-3 flex items-center gap-2 bg-amber-100 border border-amber-200 rounded-xl px-3 py-2">
                                <i class="ri-error-warning-line text-amber-600 text-base shrink-0"></i>
                                <p class="text-xs font-semibold text-amber-700">
                                    Walkaround expires tomorrow. Consider performing a new inspection today.
                                </p>
                            </div>
                        }
                    }

                    <p class="text-sm text-slate-500 mt-2">
                        Vehicle assumed and inspected. You're cleared to log your deliveries.
                    </p>
                </div>
            </div>
            <div class="mt-5 space-y-3">
                <a href="/DailyLog/Create"
                   class="flex items-center justify-center gap-2 w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-2xl transition-all shadow-md shadow-teal-200 text-sm">
                    <i class="ri-clipboard-line text-lg"></i>
                    Register Daily Log
                </a>
                <a href="/Walkaround/Create"
                   class="flex items-center justify-center gap-2 w-full border-2 border-teal-300 text-teal-700 hover:bg-teal-100 font-bold py-2.5 rounded-2xl transition-all text-sm">
                    <i class="ri-shield-check-line"></i>
                    New Walkaround Check
                </a>
                <form asp-controller="Assignment" asp-action="Unassign" method="post" class="w-full">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full border-2 border-slate-200 text-slate-400 hover:border-red-300 hover:text-red-500 font-bold py-2.5 rounded-2xl transition-all text-sm">
                        <i class="ri-arrow-go-back-line mr-1"></i> Return Vehicle
                    </button>
                </form>
            </div>
        </div>
    }

    @* FEED DE ATIVIDADES RECENTES *@
    <section class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="p-5 border-b border-slate-100">
            <h2 class="text-base font-black text-slate-800 flex items-center gap-2">
                <i class="ri-history-line text-teal-500"></i>
                Recent Activity
            </h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-center border-collapse">
                <thead class="bg-slate-50 text-slate-400 text-xs uppercase font-bold">
                    <tr>
                        <th class="px-4 py-3">Date</th>
                        <th class="px-4 py-3">Vehicle</th>
                        <th class="px-4 py-3">Del.</th>
                        <th class="px-4 py-3">Col.</th>
                        <th class="px-4 py-3">Ret.</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-600">
                    @if (Model.RecentActivities.Any())
                    {
                        foreach (var log in Model.RecentActivities)
                        {
                            <tr class="hover:bg-teal-50/50">
                                <td class="px-4 py-3 font-bold text-slate-700 text-sm">@log.LogDate.ToString("dd/MM/yy")</td>
                                <td class="px-4 py-3">
                                    <span class="bg-slate-100 px-2 py-1 rounded-lg text-xs font-black border border-slate-200">
                                        @log.RegistrationNo
                                    </span>
                                </td>
                                <td class="px-4 py-3 font-semibold text-sm">@log.Deliveries</td>
                                <td class="px-4 py-3 font-semibold text-sm">@log.Collections</td>
                                <td class="px-4 py-3 text-orange-600 font-bold text-sm">@log.Returns</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-10 text-slate-400 italic text-sm">No history found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

</div>